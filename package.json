{
  "name": "driveaway-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend\" \"cd backend && python -m app.main\"",
    "build": "npm run build -w frontend",
    "start": "npm run start -w frontend",
    "lint": "npm run lint -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {

    "sonner": "^2.0.7",
    "zustand": "^5.0.12"
  }
}
