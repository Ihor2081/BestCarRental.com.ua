{"version":3,"sources":["D:\\Курси\\DriveAway\\frontend\\src\\app\\about\\page.tsx"],"sourcesContent":["import Image from \"next/image\";\r\nimport {\r\n  Heart, Shield, Award, TrendingUp,\r\n  Globe, Users, Car, MapPin,\r\n  ShieldCheck, PhoneCall\r\n} from \"lucide-react\";\r\n\r\nexport default function AboutPage() {\r\n  return (\r\n    <main>\r\n      {/* HERO SECTION */}\r\n      <section className=\"about-hero bg-gradient-to-br from-blue-600 to-blue-800 text-white py-32 text-center\">\r\n        <div className=\"container mx-auto px-4 max-w-7xl\">\r\n          <h1 className=\"text-5xl font-extrabold mb-4\">About DriveAway</h1>\r\n          <p className=\"text-xl max-w-3xl mx-auto opacity-90\">\r\n            We're revolutionizing car rentals by combining premium vehicles, exceptional service, and cutting-edge technology to make your journey unforgettable.\r\n          </p>\r\n        </div>\r\n      </section>\r\n\r\n      {/* OUR STORY SECTION */}\r\n      <section className=\"container mx-auto px-4 max-w-7xl py-20\">\r\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\">\r\n          \r\n          {/* TEXT */}\r\n          <div>\r\n            <h2 className=\"text-4xl font-bold mb-6\">Our Story</h2>\r\n            <p className=\"text-gray-600 mb-4 leading-relaxed\">\r\n              Founded in 2018, DriveAway began with a simple mission: to make car rental accessible, affordable, and enjoyable for everyone.\r\n            </p>\r\n            <p className=\"text-gray-600 mb-4 leading-relaxed\">\r\n              What started as a small fleet of 20 vehicles has grown into a nationwide service with over 5,000 premium cars.\r\n            </p>\r\n            <p className=\"text-gray-600 leading-relaxed\">\r\n              Today, we're proud to serve over 100,000 customers annually, maintaining our commitment to quality and transparency.\r\n            </p>\r\n          </div>\r\n\r\n          {/* IMAGE */}\r\n          <div className=\"relative w-full h-[400px] lg:h-[500px]\">\r\n            <Image\r\n              src=\"/static/about/our-team.jpg\"\r\n              alt=\"DriveAway Team\"\r\n              fill\r\n              className=\"rounded-2xl shadow-xl object-cover\"\r\n              sizes=\"(max-width: 768px) 100vw, 50vw\"\r\n              priority\r\n            />\r\n          </div>\r\n\r\n        </div>\r\n      </section>\r\n\r\n      {/* NUMBERS */}\r\n      <section className=\"bg-blue-600 text-white py-20\">\r\n        <div className=\"container mx-auto px-4 max-w-7xl\">\r\n          <h2 className=\"text-3xl font-bold text-center mb-16\">DriveAway by the Numbers</h2>\r\n          <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-8 text-center\">\r\n            {[\r\n              { value: \"5,000+\", label: \"Vehicles Available\" },\r\n              { value: \"50+\", label: \"Locations\" },\r\n              { value: \"100K+\", label: \"Happy Customers\" },\r\n              { value: \"4.8★\", label: \"Average Rating\" },\r\n            ].map((item, i) => (\r\n              <div key={i}>\r\n                <div className=\"text-5xl font-extrabold mb-2\">{item.value}</div>\r\n                <div className=\"text-sm opacity-80 uppercase tracking-wider font-semibold\">{item.label}</div>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      {/* VALUES */}\r\n      <section className=\"container mx-auto px-4 max-w-7xl py-20\">\r\n        <h2 className=\"text-4xl font-bold text-center mb-16\">Our Core Values</h2>\r\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8\">\r\n          {[\r\n            { icon: Heart, title: \"Customer First\", desc: \"Your satisfaction is our priority.\" },\r\n            { icon: Shield, title: \"Trust & Transparency\", desc: \"No hidden fees.\" },\r\n            { icon: Award, title: \"Excellence\", desc: \"Top quality service.\" },\r\n            { icon: TrendingUp, title: \"Innovation\", desc: \"We improve constantly.\" },\r\n            { icon: Globe, title: \"Sustainability\", desc: \"Eco-friendly fleet.\" },\r\n            { icon: Users, title: \"Community\", desc: \"We support local communities.\" },\r\n          ].map((value, i) => (\r\n            <div key={i} className=\"bg-white p-10 rounded-2xl shadow-sm text-center hover:-translate-y-2 hover:shadow-xl transition-all duration-300\">\r\n              <div className=\"w-16 h-16 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-6\">\r\n                <value.icon className=\"w-8 h-8\" />\r\n              </div>\r\n              <h3 className=\"text-xl font-bold mb-4\">{value.title}</h3>\r\n              <p className=\"text-gray-500 text-sm\">{value.desc}</p>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </section>\r\n\r\n      {/* WHY */}\r\n      <section className=\"container mx-auto px-4 max-w-7xl py-20\">\r\n        <h2 className=\"text-4xl font-bold text-center mb-16\">Why Choose DriveAway?</h2>\r\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\r\n          {[\r\n            { icon: Car, title: \"Premium Fleet\", desc: \"Latest cars maintained to highest standards.\" },\r\n            { icon: MapPin, title: \"Convenient Locations\", desc: \"50+ pickup locations.\" },\r\n            { icon: ShieldCheck, title: \"Flexible Policies\", desc: \"No hidden fees.\" },\r\n            { icon: PhoneCall, title: \"24/7 Support\", desc: \"Always here for you.\" },\r\n          ].map((why, i) => (\r\n            <div key={i} className=\"bg-white p-8 rounded-2xl flex gap-6 shadow-sm\">\r\n              <div className=\"w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center\">\r\n                <why.icon className=\"w-6 h-6\" />\r\n              </div>\r\n              <div>\r\n                <h3 className=\"text-lg font-bold mb-2\">{why.title}</h3>\r\n                <p className=\"text-gray-500 text-sm\">{why.desc}</p>\r\n              </div>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </section>\r\n\r\n    </main>\r\n  );\r\n}"],"names":["AboutPage","main","section","className","div","h1","p","h2","Image","src","alt","fill","sizes","priority","value","label","map","item","i","icon","Heart","title","desc","Shield","Award","TrendingUp","Globe","Users","h3","Car","MapPin","ShieldCheck","PhoneCall","why"],"mappings":";;;;+BAOA;;;eAAwBA;;;;8DAPN;6BAKX;;;;;;AAEQ,SAASA;IACtB,qBACE,sBAACC;;0BAEC,qBAACC;gBAAQC,WAAU;0BACjB,cAAA,sBAACC;oBAAID,WAAU;;sCACb,qBAACE;4BAAGF,WAAU;sCAA+B;;sCAC7C,qBAACG;4BAAEH,WAAU;sCAAuC;;;;;0BAOxD,qBAACD;gBAAQC,WAAU;0BACjB,cAAA,sBAACC;oBAAID,WAAU;;sCAGb,sBAACC;;8CACC,qBAACG;oCAAGJ,WAAU;8CAA0B;;8CACxC,qBAACG;oCAAEH,WAAU;8CAAqC;;8CAGlD,qBAACG;oCAAEH,WAAU;8CAAqC;;8CAGlD,qBAACG;oCAAEH,WAAU;8CAAgC;;;;sCAM/C,qBAACC;4BAAID,WAAU;sCACb,cAAA,qBAACK,cAAK;gCACJC,KAAI;gCACJC,KAAI;gCACJC,IAAI;gCACJR,WAAU;gCACVS,OAAM;gCACNC,QAAQ;;;;;;0BAQhB,qBAACX;gBAAQC,WAAU;0BACjB,cAAA,sBAACC;oBAAID,WAAU;;sCACb,qBAACI;4BAAGJ,WAAU;sCAAuC;;sCACrD,qBAACC;4BAAID,WAAU;sCACZ;gCACC;oCAAEW,OAAO;oCAAUC,OAAO;gCAAqB;gCAC/C;oCAAED,OAAO;oCAAOC,OAAO;gCAAY;gCACnC;oCAAED,OAAO;oCAASC,OAAO;gCAAkB;gCAC3C;oCAAED,OAAO;oCAAQC,OAAO;gCAAiB;6BAC1C,CAACC,GAAG,CAAC,CAACC,MAAMC,kBACX,sBAACd;;sDACC,qBAACA;4CAAID,WAAU;sDAAgCc,KAAKH,KAAK;;sDACzD,qBAACV;4CAAID,WAAU;sDAA6Dc,KAAKF,KAAK;;;mCAF9EG;;;;;0BAUlB,sBAAChB;gBAAQC,WAAU;;kCACjB,qBAACI;wBAAGJ,WAAU;kCAAuC;;kCACrD,qBAACC;wBAAID,WAAU;kCACZ;4BACC;gCAAEgB,MAAMC,kBAAK;gCAAEC,OAAO;gCAAkBC,MAAM;4BAAqC;4BACnF;gCAAEH,MAAMI,mBAAM;gCAAEF,OAAO;gCAAwBC,MAAM;4BAAkB;4BACvE;gCAAEH,MAAMK,kBAAK;gCAAEH,OAAO;gCAAcC,MAAM;4BAAuB;4BACjE;gCAAEH,MAAMM,uBAAU;gCAAEJ,OAAO;gCAAcC,MAAM;4BAAyB;4BACxE;gCAAEH,MAAMO,kBAAK;gCAAEL,OAAO;gCAAkBC,MAAM;4BAAsB;4BACpE;gCAAEH,MAAMQ,kBAAK;gCAAEN,OAAO;gCAAaC,MAAM;4BAAgC;yBAC1E,CAACN,GAAG,CAAC,CAACF,OAAOI,kBACZ,sBAACd;gCAAYD,WAAU;;kDACrB,qBAACC;wCAAID,WAAU;kDACb,cAAA,qBAACW,MAAMK,IAAI;4CAAChB,WAAU;;;kDAExB,qBA